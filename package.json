{
  "name": "playwright-typescript-self-healing-framework",
  "version": "1.0.0",
  "description": "E2E automation framework using TS + Playwright with custom local Ollama.",
  "author": "RLeonir uaicowboybr@gmail.com",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "test": "playwright test --project=chromium",
    "test:ui": "playwright test --ui --project=chromium",
    "test:debug": "playwright test --debug",
    "test:watch": "playwright test --watch",
    "install:browsers": "playwright install chromium --with-deps"
  },
  "devDependencies": {
    "@playwright/test": "1.59.1",
    "@types/node": "25.5.0",
    "typescript": "6.0.2",
    "zod": "4.3.6",
    "dotenv": "16.4.7",
    "eslint": "^9.22.0",
    "@eslint/js": "^9.0.0",
    "eslint-config-prettier": "^9.1.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "prettier": "^3.5.0",
    "ollama": "0.6.3"
  }
}
